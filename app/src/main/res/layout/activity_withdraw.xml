<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#F9F9F9"
    tools:context=".activities.WithdrawActivity"
    >

    <!-- Back Button -->
    <ImageView
        android:id="@+id/backImg"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:padding="6dp"
        android:src="@drawable/ic_arrow_back"
        android:contentDescription="Back"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginStart="8dp" />

    <!-- Title -->
    <TextView
        android:id="@+id/pageTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Withdraw via UPI"
        android:textSize="20sp"
        android:textColor="#000000"
        android:fontFamily="@font/poppins_bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/backImg"
        android:layout_marginStart="12dp"
        android:layout_marginTop="18dp" />

    <!-- Balance Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/balanceCard"
        android:layout_width="0dp"
        android:layout_margin="16dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        android:backgroundTint="#FFFFFF"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/pageTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:text="Available Balance"
                android:textColor="#666666"
                android:textSize="14sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"  />

            <TextView
                android:id="@+id/balanceAmount"
                android:text="₹250.00"

                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="22sp"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/poppins_bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- UPI ID Input -->
    <EditText
        android:id="@+id/upiId"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Enter UPI ID"

        android:layout_margin="16dp"
        android:inputType="textEmailAddress"
        android:layout_marginTop="24dp"
        android:background="@drawable/edittext_background"
        android:padding="14dp"
        android:textColor="#000000"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/balanceCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Amount Input -->
    <EditText
        android:id="@+id/withdrawAmount"
        android:layout_width="0dp"

        android:layout_margin="16dp"
        android:layout_height="wrap_content"
        android:hint="Enter amount "
        android:inputType="numberDecimal"
        android:layout_marginTop="16dp"
        android:background="@drawable/edittext_background"
        android:padding="14dp"
        android:textColor="#000000"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/upiId"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Withdraw Button -->
    <Button
        android:id="@+id/withdrawButton"
        android:layout_width="0dp"

        android:layout_margin="16dp"
        android:layout_height="wrap_content"
        android:text="Withdraw Now"
        android:layout_marginTop="24dp"
        android:background="@drawable/primary_button"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:fontFamily="@font/poppins_medium"
        android:padding="14dp"
        app:layout_constraintTop_toBottomOf="@id/withdrawAmount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Info Note -->
    <TextView
        android:id="@+id/withdrawNote"
        android:layout_width="0dp"

        android:layout_margin="16dp"
        android:layout_height="wrap_content"
        android:text="Withdrawals are processed within 24 hours to your UPI ID. Please ensure it is correct."
        android:textSize="12sp"
        android:textColor="#999999"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/withdrawButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:layout_height="0dp"

        android:layout_margin="16dp"
        android:background="@drawable/white_corner_background"
        android:padding="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/withdrawNote"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_width="match_parent"
        >
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/transactionList"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/withdrawNote"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            />
    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>
