<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F9F9">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/taskCompletionLayout"
        android:layout_width="match_parent"
        android:visibility="visible"
        android:layout_height="match_parent">

    <!-- Back Button -->
        <ImageView
            android:id="@+id/backButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="16dp"
            android:visibility="visible"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="6dp"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    <!-- Page Title -->
        <TextView
            android:id="@+id/topbar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:layout_marginStart="18dp"
            android:layout_marginTop="18dp"
            android:visibility="visible"
            android:fontFamily="@font/poppins_bold"
            android:text="Task Completed"
            android:textColor="#000000"
            android:textSize="20sp"
            app:layout_constraintStart_toEndOf="@id/backButton"
            app:layout_constraintTop_toTopOf="parent" />



        <ImageView

            android:id="@+id/successEmoji"
            android:layout_width="90dp"
            android:layout_height="90dp"

            android:layout_marginTop="40dp"
            app:layout_constraintTop_toBottomOf="@id/topbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:src="@drawable/ic_check_done"
            app:tint="@color/colorPrimary" />

    <!-- Message -->
    <TextView
        android:id="@+id/successMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="You’ve successfully completed the task!"
        android:textSize="16sp"
        android:textColor="#000000"
        android:fontFamily="@font/poppins_medium"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/successEmoji"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Task Title -->
    <TextView
        android:id="@+id/taskTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Task: Read News"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/successMessage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Reward -->
    <TextView
        android:id="@+id/taskReward"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+ ₹0.00 Added"
        android:textSize="23sp"
        android:textColor="#1E8E3E"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/poppins_bold"
        app:layout_constraintTop_toBottomOf="@id/taskTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Back to Home Button -->
        <Button
            android:id="@+id/backToTasksBtn"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginTop="40dp"
            android:background="@drawable/outlined_button"
            android:backgroundTint="@color/colorPrimary"
            android:fontFamily="@font/poppins_medium"
            android:text="Back to Tasks"
            android:textColor="@color/colorPrimary"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@+id/successMessage"
            app:layout_constraintStart_toStartOf="@+id/successMessage"
            app:layout_constraintTop_toBottomOf="@id/taskReward" />

    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/redirectionLayout"
        android:layout_width="match_parent"
        android:background="@color/colorNew"
        android:visibility="gone"
        android:layout_height="match_parent">


        <TextView
            android:id="@+id/taskCheckingTxt"
            android:layout_width="wrap_content"
            android:padding="4dp"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:text="Redirecting to task site link\nChecking Task...\n don't close"
            android:textSize="14sp"
            android:textColor="@color/colorNew"
            android:background="#ffffff"
            android:layout_marginTop="20sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
